---
import Layout from "../layouts/Layout.astro";
import type { AlbumsResponse } from "../layouts/types/strapi";

const strapiUrl = import.meta.env.STRAPI_URL;

const response = await fetch(`${strapiUrl}/api/albums?populate=*`);
const { data: albums }: AlbumsResponse = await response.json();
---

<Layout title="Vinyl Collection">
    <div class="flex flex-col w-full">
      {albums.slice().reverse().map((album) => (
        <div class="group flex items-center text-lg mb-4 odd:self-start even:self-end odd:flex-row even:flex-row-reverse">
          <img
            src={`${strapiUrl}${album.cover.url}`}
            alt={`${album.name} - ${album.artist}`}
            class="w-24 h-24 rounded-lg shadow-lg object-cover"
          />
          <div class="mx-2 group-even:text-right group-odd:text-left">
            <p class="text-2xl md:text-3xl">{album.name}</p>
            <p class="text-lg md:text-xl">{album.artist}</p>
          </div>
        </div>
      ))}
    </div>
  </Layout>