---
import NavBar from "../components/NavBar.astro";
import "../styles/global.css";
import "@fontsource/plus-jakarta-sans";

interface Props {
	title?: string;
}

const { title = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="https://avatars.githubusercontent.com/u/41494790?v=4">
		<title>Evan Whelan{title == "" ? "" : ` - ${title}`}</title>
	</head>
	<body class="bg-zinc-900 font-jakarta text-neutral-200 min-h-screen">
		<div class="mx-auto w-full max-w-[75ch] px-2">
			<NavBar />
			<slot />
		</div>
	</body>
</html>